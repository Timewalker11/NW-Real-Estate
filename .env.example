# Secret key used to sign login session JWTs. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to "true" once the site is served over HTTPS so the session cookie
# is only sent over secure connections. Keep "false" for local http development.
COOKIE_SECURE=false

# Gmail account used to send the welcome email on signup. GMAIL_APP_PASSWORD
# must be a Gmail "app password" (not your normal login password) - create
# one at https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Address that receives contact form submissions. Defaults to GMAIL_USER
# if left blank.
CONTACT_RECIPIENT=

# Directory where the SQLite database file (app.db) is stored. In
# production this MUST point at a mounted persistent volume (e.g. a
# Railway Volume's mount path), otherwise all signed-up users and
# contact messages are wiped out on every deploy/restart. Leave blank
# for local development to use the project root.
DATA_DIR=
